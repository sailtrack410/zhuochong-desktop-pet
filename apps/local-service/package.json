{
  "name": "@zhuochong/local-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/apps/local-service/src/index.js",
  "types": "./dist/apps/local-service/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/local-service/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/main.ts",
    "postinstall": "node ../../node_modules/@electron/rebuild/lib/cli.js -m . -o better-sqlite3 2>/dev/null || echo '[local-service] better-sqlite3 rebuild skipped (electron not found)'"
  },
  "dependencies": {
    "@zhuochong/shared": "workspace:*",
    "@zhuochong/ui-contracts": "workspace:*",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
